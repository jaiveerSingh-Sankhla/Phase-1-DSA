#include<iostream>
using namespace std;
class Student
{
    string name ;
    int age;
    public: // setter fxn set the private data members
    void setter(string n, int a ){
        name = n;
        age = a;
    
    }
    //getter fxn return the private data member val
    int getter(){
        return age;
    }
    void display(){
        cout<<name<<endl;
        cout<<age<<endl;

    }

};
int main(){
    Student obj1;
    obj1.setter("Jaiveer", 21);
    cout<<obj1.getter();
}
